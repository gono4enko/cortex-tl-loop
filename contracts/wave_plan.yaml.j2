# Wave Plan for project: {{ project_id }}
# Generated by Cortex Team Lead (GLM-5.2)
# Date: {{ date }}

wave_id: "{{ wave_id }}"
project_id: "{{ project_id }}"
description: "{{ description }}"

tasks:
{% for task in tasks %}
  - id: "{{ task.id }}"
    title: "{{ task.title }}"
    objective: "{{ task.objective }}"
    executor: "{{ task.executor }}"
    priority: {{ task.priority }}
    touched_files:
{% for f in task.touched_files %}
      - "{{ f }}"
{% endfor %}
    forbidden_files:
{% for f in task.forbidden_files %}
      - "{{ f }}"
{% endfor %}
    acceptance_criteria:
{% for ac in task.acceptance_criteria %}
      - "{{ ac }}"
{% endfor %}
    verify_command: "{{ task.verify_command }}"
{% endfor %}

# Validation: tasks in same wave MUST NOT share touched_files
